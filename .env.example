# GEMINI_API_KEY: Required for Gemini AI API calls (if used).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# SUPABASE_URL: Your Supabase Project URL (e.g., https://xyz.supabase.co)
SUPABASE_URL=""

# SUPABASE_ANON_KEY: Your Supabase Public Anon Key
SUPABASE_ANON_KEY=""

# SUPABASE_SERVICE_ROLE_KEY: Your Supabase Service Role Key (Required for server-side user management like banning, password resets, and deleting users)
SUPABASE_SERVICE_ROLE_KEY=""
